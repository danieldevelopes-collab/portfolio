{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "A living portfolio that documents every public repo and runs the web ones live. Manifest-driven static site, free-tier hostable.",
  "scripts": {
    "build": "node scripts/build.mjs",
    "sync": "node scripts/sync.mjs",
    "serve": "node scripts/serve.mjs",
    "dev": "node scripts/build.mjs && node scripts/serve.mjs",
    "clean": "node -e \"import('node:fs').then(fs=>{fs.rmSync('dist',{recursive:true,force:true});console.log('removed dist/')})\""
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
